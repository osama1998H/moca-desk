{
  "name": "@osama1998h/desk",
  "version": "0.1.7",
  "description": "Moca Desk - React frontend framework for Moca business applications",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/osama1998H/moca.git",
    "directory": "desk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "predev": "test -f .moca-extensions.ts || echo '// No extensions' > .moca-extensions.ts",
    "pretypecheck": "test -f .moca-extensions.ts || echo '// No extensions' > .moca-extensions.ts",
    "prebuild": "test -f .moca-extensions.ts || echo '// No extensions' > .moca-extensions.ts",
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -p tsconfig.lib.json && tsc-alias -p tsconfig.lib.json && cp src/index.css dist/index.css",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "audit:skylos": "skylos . -a --exclude-folder node_modules --exclude-folder dist --exclude-folder .vite --baseline",
    "audit:skylos:baseline": "skylos baseline . --exclude-folder node_modules --exclude-folder dist --exclude-folder .vite"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.96.2",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "tsc-alias": "^1.8.16",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  }
}
